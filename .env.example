# BHV App Configuration
# Copy this file to .env and fill in your values.

# ── Core ─────────────────────────────────────────────────────────────────────
# Secret key for session encryption (CHANGE THIS in production!)
SECRET_KEY=change-me-in-production

# Flask environment: 'development' or 'production'
FLASK_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string (optional; uses embedded TinyDB if not set)
# MONGO_URI=mongodb://localhost:27017/bhv

# ── Authentication ────────────────────────────────────────────────────────────
# Google OAuth Client ID (optional; enables Google Sign-In buttons)
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# ── Storage Mode ──────────────────────────────────────────────────────────────
# 'local'  — store images in uploads/ using local Git (default)
# 'github' — store images in private GitHub repos, one per patient
STORAGE_MODE=local

# ── GitHub Storage (required when STORAGE_MODE=github) ───────────────────────
# A GitHub Personal Access Token with 'repo' scope.
# The admin/service account creates private repos on behalf of patients.
# GITHUB_ADMIN_TOKEN=ghp_your_token_here
# GITHUB_ADMIN_USERNAME=your-github-username
# GITHUB_ORG=your-org-name   # optional: create repos under an org instead

# ── Image Upload Limits ───────────────────────────────────────────────────────
# Maximum upload size in megabytes (default: 10 MB)
MAX_IMAGE_SIZE_MB=10

# ── LLM / AI ─────────────────────────────────────────────────────────────────
# OpenRouter API key for the Ask Me AI assistant (optional)
# Get from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-key

# ── Admin Seed ───────────────────────────────────────────────────────────────
# Auto-created on first startup if no admin exists yet.
ADMIN_EMAIL=admin@bhv.com
ADMIN_PASSWORD=Admin@1234

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to 1 to enable verbose request logging for diagnosing CSRF/upload issues
# BHV_REQUEST_DEBUG=0
